# ── Runtime ───────────────────────────────────────────────
NODE_ENV=development
# api | worker  (selects the bootstrap path in src/main.ts)
RUN_MODE=api
PORT=3000

# ── PostgreSQL ────────────────────────────────────────────
# Option A: a single connection URL (Neon / Supabase / RDS). Takes precedence.
# DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# Option B: discrete fields (used when DATABASE_URL is unset, e.g. docker compose)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=task_platform
# NEVER true outside of throwaway local dev — schema changes go through migrations
DB_SYNCHRONIZE=false
DB_LOGGING=false
# true for managed Postgres over TLS (Neon/Supabase/RDS); false for local/docker
DB_SSL=false

# ── Redis / queue (used from Phase 6 onward) ──────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# Flip on to use BullMQ; provide a REDIS_URL (e.g. Upstash rediss://...).
QUEUE_ENABLED=false
# REDIS_URL=rediss://default:password@host:6379

# ── Auth (used from Phase 1 onward) ───────────────────────
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_TTL=7d
